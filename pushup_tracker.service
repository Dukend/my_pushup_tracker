[Unit]
Description=Pushup Tracker Telegram Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/pushup_tracker
ExecStart=/opt/pushup_tracker/venv/bin/python main.py
Restart=always
RestartSec=5

# Load variables from .env file
EnvironmentFile=/opt/pushup_tracker/.env

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/pushup_tracker/data

[Install]
WantedBy=multi-user.target
